{
    "name": "@magic-link-sso/nextjs",
    "version": "0.9.0",
    "description": "Magic Link SSO for Next.js",
    "keywords": [
        "auth",
        "jwt",
        "magic-link",
        "nextjs",
        "sso"
    ],
    "homepage": "https://github.com/magic-link-sso/magic-sso#readme",
    "bugs": {
        "url": "https://github.com/magic-link-sso/magic-sso/issues"
    },
    "license": "MIT",
    "author": {
        "name": "Wojciech Polak"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/magic-link-sso/magic-sso.git",
        "directory": "packages/nextjs"
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "build": "pnpm run clean && tsc -p tsconfig.json",
        "build:watch": "tsc --watch",
        "clean": "rm -rf dist tsconfig.tsbuildinfo",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "lint": "oxlint .",
        "prepublishOnly": "pnpm run lint && pnpm run test && pnpm run build",
        "test": "vitest run",
        "typecheck": "tsc -p tsconfig.typecheck.json"
    },
    "dependencies": {
        "jose": "^6.2.3"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "next": "^16.2.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "engines": {
        "node": ">=24.15.0"
    }
}
