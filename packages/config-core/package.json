{
    "name": "@magic-link-sso/config-core",
    "version": "1.2.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./runtime": {
            "types": "./dist/runtime.d.ts",
            "default": "./dist/runtime.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "build:watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
        "format": "oxfmt package.json tsconfig.json tsconfig.typecheck.json vitest.config.ts src",
        "format:check": "oxfmt --check package.json tsconfig.json tsconfig.typecheck.json vitest.config.ts src",
        "lint": "oxlint src",
        "test": "vitest run",
        "typecheck": "tsc -p tsconfig.typecheck.json"
    },
    "dependencies": {
        "smol-toml": "^1.6.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^25.9.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=24.15.0"
    }
}
