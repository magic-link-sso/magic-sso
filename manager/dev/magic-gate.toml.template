[gate]
port = 4000
mode = "${MAGIC_GATE_RENDER_MODE}"
namespace = "${MAGIC_GATE_RENDER_NAMESPACE}"
publicOrigin = "${MAGIC_GATE_RENDER_PUBLIC_ORIGIN}"
upstreamUrl = "${MAGIC_GATE_RENDER_UPSTREAM_URL}"
directUse = ${MAGIC_GATE_RENDER_DIRECT_USE}
requestTimeoutMs = ${MAGIC_GATE_RENDER_REQUEST_TIMEOUT_MS}
rateLimitMax = ${MAGIC_GATE_RENDER_RATE_LIMIT_MAX}
rateLimitWindowMs = ${MAGIC_GATE_RENDER_RATE_LIMIT_WINDOW_MS}
trustProxy = ${MAGIC_GATE_RENDER_TRUST_PROXY}
wsEnabled = ${MAGIC_GATE_RENDER_WS_ENABLED}

[auth]
jwtSecret = "${MAGIC_GATE_RENDER_JWT_SECRET}"
previewSecret = "${MAGIC_GATE_RENDER_PREVIEW_SECRET}"
serverUrl = "${MAGIC_GATE_RENDER_SERVER_URL}"

[cookie]
name = "${MAGIC_GATE_RENDER_COOKIE_NAME}"
path = "/"
maxAge = ${MAGIC_GATE_RENDER_COOKIE_MAX_AGE}
