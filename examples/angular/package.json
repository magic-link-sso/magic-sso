{
    "name": "example-app-angular",
    "version": "1.1.1",
    "private": true,
    "scripts": {
        "build": "pnpm --filter @magic-link-sso/angular build && NODE_OPTIONS=--dns-result-order=ipv4first HOST=0.0.0.0 ng build",
        "dev": "node scripts/dev.mjs",
        "format": "oxfmt angular.json package.json tsconfig.json tsconfig.app.json src tests README.md vitest.config.ts",
        "format:check": "oxfmt --check angular.json package.json tsconfig.json tsconfig.app.json src tests README.md vitest.config.ts",
        "lint": "oxlint src tests vitest.config.ts",
        "start": "node dist/example-app-angular/server/server.mjs",
        "test": "vitest run",
        "typecheck": "tsc -p tsconfig.typecheck.json"
    },
    "dependencies": {
        "@angular/common": "21.2.17",
        "@angular/core": "21.2.17",
        "@angular/forms": "21.2.17",
        "@angular/platform-browser": "21.2.17",
        "@angular/platform-server": "21.2.17",
        "@angular/router": "21.2.17",
        "@angular/ssr": "21.2.15",
        "@magic-link-sso/angular": "workspace:*",
        "@magic-link-sso/config-core": "workspace:*",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "magic-sso-example-ui": "workspace:*",
        "rxjs": "^7.8.2",
        "tslib": "^2.8.1",
        "zone.js": "^0.16.2"
    },
    "devDependencies": {
        "@angular/build": "21.2.15",
        "@angular/cli": "21.2.15",
        "@angular/compiler-cli": "21.2.17",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.3",
        "typescript": "~5.9.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=24.15.0"
    }
}
