{
    "name": "example-app-nextjs",
    "version": "1.1.1",
    "private": true,
    "scripts": {
        "clean": "rm -rf .next",
        "dev": "node scripts/ensure-env.mjs && pnpm run clean && pnpm --filter @magic-link-sso/nextjs build && exec next dev --webpack -p 3001",
        "build": "node scripts/ensure-env.mjs && pnpm run clean && pnpm --filter @magic-link-sso/nextjs build && next build --webpack",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "lint": "oxlint .",
        "start": "node scripts/ensure-env.mjs && next start -p 3001",
        "test": "node --test",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@magic-link-sso/nextjs": "workspace:*",
        "jose": "^6.2.3",
        "jwt-decode": "^4.0.0",
        "magic-sso-example-ui": "workspace:*",
        "next": "^16.2.6",
        "react": "^19.2.6",
        "react-dom": "^19.2.6"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.0",
        "@types/node": "^25.6.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "postcss": "^8.5.14",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=24.15.0"
    }
}
