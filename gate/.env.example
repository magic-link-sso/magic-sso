# Compose bootstrap values for the local Gate stack.
# The rendered Gate config itself lives in `gate/magic-gate.toml` files.

# Shared SSO/server bootstrap
MAGICSSO_SERVER_URL=http://localhost:3000
MAGICSSO_JWT_SECRET=gate-dev-jwt-secret-1234567890abcd
MAGICSSO_COOKIE_NAME=magic-sso
MAGICSSO_COOKIE_MAX_AGE=3600

# Local proxy hosts and example access policy
PUBLIC_PROXY_PORT=4306
SSO_PUBLIC_HOST=sso.localhost
PRIVATE1_PUBLIC_HOST=private1.localhost
PRIVATE2_PUBLIC_HOST=private2.localhost
PRIVATE1_ALLOWED_EMAIL=private1@example.com
PRIVATE2_ALLOWED_EMAIL=private2@example.com

# Example upstream ports
PRIVATE1_UPSTREAM_PORT=3007
PRIVATE2_UPSTREAM_PORT=3008

# Mail sink
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_HOST=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_SMTP_USER=mailpit
MAILPIT_SMTP_PASS=mailpit

# Gate TOML render values used by the Docker Compose bootstrap step
MAGIC_GATE_RENDER_PUBLIC_ORIGIN=http://localhost:4000
MAGIC_GATE_RENDER_UPSTREAM_URL=http://localhost:3007
MAGIC_GATE_RENDER_MODE=subdomain
MAGIC_GATE_RENDER_DIRECT_USE=true
MAGIC_GATE_RENDER_SERVER_URL=http://sso.localhost:4306
MAGIC_GATE_RENDER_JWT_SECRET=gate-dev-jwt-secret-1234567890abcd
MAGIC_GATE_RENDER_COOKIE_NAME=magic-sso
MAGIC_GATE_RENDER_COOKIE_MAX_AGE=3600
MAGIC_GATE_RENDER_TRUST_PROXY=false
MAGIC_GATE_RENDER_REQUEST_TIMEOUT_MS=10000
MAGIC_GATE_RENDER_RATE_LIMIT_MAX=240
MAGIC_GATE_RENDER_RATE_LIMIT_WINDOW_MS=60000
MAGIC_GATE_RENDER_WS_ENABLED=true
MAGIC_GATE_RENDER_NAMESPACE=/_magicgate

# Dev-only secrets shared by the local stack
MAGICSSO_DEV_CSRF_SECRET=gate-dev-csrf-secret-1234567890abc
MAGICSSO_DEV_EMAIL_SECRET=gate-dev-email-secret-1234567890ab
