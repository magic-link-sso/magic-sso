{
    "name": "magic-sso-gate",
    "version": "1.2.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "pnpm --filter @magic-link-sso/config-core build && tsc -p tsconfig.json",
        "dev": "node --watch --import tsx src/main.ts",
        "format": "oxfmt package.json tsconfig.json vitest.config.ts .env.example .env.prod.example README.md magic-gate.example.toml Dockerfile docker-compose.yml docker-compose.prod.yml dev src tests",
        "format:check": "oxfmt --check package.json tsconfig.json vitest.config.ts .env.example .env.prod.example README.md magic-gate.example.toml Dockerfile docker-compose.yml docker-compose.prod.yml dev src tests",
        "lint": "oxlint src tests",
        "start": "node dist/main.js",
        "test": "pnpm --filter @magic-link-sso/config-core build && vitest run --config vitest.config.ts",
        "typecheck": "pnpm --filter @magic-link-sso/config-core build && tsc -p tsconfig.typecheck.json"
    },
    "dependencies": {
        "@fastify/cookie": "^11.0.2",
        "@fastify/formbody": "^8.0.2",
        "@magic-link-sso/config-core": "workspace:*",
        "dotenv": "^17.4.2",
        "fastify": "^5.8.5",
        "ioredis": "^5.11.1",
        "jose": "^6.2.3",
        "magic-sso-example-ui": "workspace:*",
        "smol-toml": "^1.6.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^25.9.3",
        "@types/ws": "^8.18.1",
        "tsx": "^4.22.4",
        "typescript": "^5.9.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=24.15.0"
    }
}
