    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noEmit": true,
        "strict": true,
        "target": "ES2023",
        "types": ["node", "@playwright/test"]
    },
    "include": ["playwright.config.ts", "src/**/*.ts", "src/**/*.d.mts", "tests/**/*.ts"]
}
