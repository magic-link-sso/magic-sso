{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "ignorePatterns": ["**/.next/**", "**/.turbo/**", "**/dist/**", "**/node_modules/**"],
    "semi": true,
    "singleQuote": true,
    "proseWrap": "always",
    "overrides": [
        {
            "files": ["**/*.md"],
            "options": {
                "printWidth": 80
            }
        }
    ]
}
